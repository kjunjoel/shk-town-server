	set {_inv} to chest inventory with 6 rows named "{@prefix} 관리자 세부 명령어"

	# 스마트폰 GUI
	set slot 13 of {_inv} to stick named "&f" with custom model data 2001

	set {_item} to paper named "&bSHK WORLD &f| &e&l예산" with custom model data 1 with lore "&7└ 예산과 관련된 명령어를 확인합니다."
	set slot 1 of {_inv} to {_item}

	set {_item} to sunflower named "&bSHK WORLD &f| &e&l빌딩" with custom model data 1 with lore "&7└ 빌딩과 관련된 명령어를 확인합니다."
	set slot 2 of {_inv} to {_item}

	set {_item} to sunflower named "&bSHK WORLD &f| &e&l버스" with custom model data 1014 with lore "&7└ 버스와 관련된 명령어를 확인합니다."
	set slot 3 of {_inv} to {_item}

	set {_item} to sunflower named "&bSHK WORLD &f| &e&l캐시" with custom model data 1008 with lore "&7└ 캐시와 관련된 명령어를 확인합니다."
	set slot 4 of {_inv} to {_item}

