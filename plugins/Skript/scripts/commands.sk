	set {_item} to paper named "&bSHK WORLD &f| &e&l관리" with custom model data 37 with lore "&7└ 서버 관리와 관련된 명령어를 확인합니다."
	set slot 24 of {_inv} to {_item}

	set {_item} to book named "&bSHK WORLD &f| &e&l계좌" with lore "&7└ 플레이어의 계좌와 관련된 명령어를 확인합니다."
	set slot 25 of {_inv} to {_item}

	set {_item} to "Lantum" parsed as offlineplayer's skull named "&bSHK WORLD &f| &e&l파벌" with lore "&7└ 파벌과 관련된 명령어를 확인합니다."
	set slot 37 of {_inv} to {_item}

	set {_item} to "GyeongRye" parsed as offlineplayer's skull named "&bSHK WORLD &f| &e&l선거관리위원회" with lore "&7└ 선거와 관련된 명령어를 확인합니다."
