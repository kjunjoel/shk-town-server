	set {_item} to "GyeongRye" parsed as offlineplayer's skull named "&bSHK WORLD &f| &e&l파벌" with custom model data 95 with lore "&7└ 파벌에 대해서 알아봅니다."
	set slot 2 of {_inv} to {_item}

	set {_item} to "Mir_Dragon" parsed as offlineplayer's skull named "&bSHK WORLD &f| &e&l선거 및 투표" with custom model data 95 with lore "&7└ 투표(선거)에 대해서 알아봅니다."
	set slot 3 of {_inv} to {_item}

	set {_item} to "rldn12134" parsed as offlineplayer's skull named "&bSHK WORLD &f| &e&l주식 및 코인" with custom model data 95 with lore "&7└ 주식 및 코인에 대해서 알아봅니다."
	set slot 4 of {_inv} to {_item}

