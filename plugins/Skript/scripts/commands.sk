options:
	# 접두사
	prefix: &f쀄 &d|&f
	gui: &d[&f&l명령어&d]&f


function commandGUI(p: player):
	set {_inv} to chest inventory with 3 rows named "{@prefix} 명령어 목록 선택"
	set {_item} to rose bush named "&bSHK WORLD &f| &e&l명령어(유저) &f모음" with lore "&7└ 유저가 사용할 수 있는 명령어를 확인합니다."
	set slot 11 of {_inv} to {_item}

	set {_item} to paper named "&bSHK WORLD &f| &e&l명령어(가이드) &f모음" with custom model data 68 with lore "&7└ 가이드가 사용할 수 있는 명령어를 확인합니다."
	set slot 13 of {_inv} to {_item}

	set {_item} to paper named "&bSHK WORLD &f| &e&l명령어(관리자) &f모음" with custom model data 37 with lore "&7└ 관리자가 사용할 수 있는 명령어를 확인합니다."
	set slot 15 of {_inv} to {_item}
	open {_inv} to {_p}


function commandUserGui(p: player):
	set {_inv} to chest inventory with 6 rows named "{@prefix} 유저 세부 명령어"

	set slot 13 of {_inv} to stick named "&f" with custom model data 2001

