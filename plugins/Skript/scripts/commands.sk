	set slot 7 of {_inv} to {_item}

	set {_item} to paper named "&bSHK WORLD &f| &e&l정보관리" with custom model data 107 with lore "&7└ 유저 정보 관리와 관련된 명령어를 확인합니다."
	set slot 19 of {_inv} to {_item}

	set {_item} to paper named "&bSHK WORLD &f| &e&l채팅" with custom model data 5 with lore "&7└ 채팅 스파이와 관련된 명령어를 확인합니다."
	set slot 20 of {_inv} to {_item}

	set {_item} to sunflower named "&bSHK WORLD &f| &e&l칭호" with custom model data 1006 with lore "&7└ 칭호와 관련된 명령어를 확인합니다."
	set slot 21 of {_inv} to {_item}

	set {_item} to sunflower named "&bSHK WORLD &f| &e&l학교" with custom model data 11 with lore "&7└ 학교와 관련된 명령어를 확인합니다."
	set slot 22 of {_inv} to {_item}

	set {_item} to paper named "&bSHK WORLD &f| &e&l가이드관리" with custom model data 68 with lore "&7└ 가이드 정보 관리와 관련된 명령어를 확인합니다."
