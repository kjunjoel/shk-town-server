function commandGuideGui(p: player):
	set {_inv} to chest inventory with 1 rows named "{@prefix} 가이드 세부 명령어"

	# 1열 하얀색 유리
	set {_item} to white stained glass pane named "&f"
	set slot 1, 3, 5, 7 of {_inv} to {_item}

	set {_item} to sunflower named "&bSHK WORLD &f| &e&l학교" with custom model data 11 with lore "&7└ 학교와 관련된 명령어를 확인합니다."
	set slot 0 of {_inv} to {_item}

	set {_item} to sunflower named "&bSHK WORLD &f| &e&l경고" with custom model data 1011 with lore "&7└ 경고와 관련된 명령어를 확인합니다."
	set slot 2 of {_inv} to {_item}

	set {_item} to sunflower named "&bSHK WORLD &f| &e&l채팅금지" with custom model data 1010 with lore "&7└ 채팅금지와 관련된 명령어를 확인합니다."
	set slot 4 of {_inv} to {_item}

	set {_item} to paper named "&bSHK WORLD &f| &e&l주의" with custom model data 65 with lore "&7└ 주의와 관련된 명령어를 확인합니다."
	set slot 6 of {_inv} to {_item}

	set {_item} to paper named "&bSHK WORLD &f| &e&l가이드" with custom model data 68 with lore "&7└ 가이드의 복지 및 특별 권한에 관련된 명령어를 확인합니다."
	set slot 8 of {_inv} to {_item}
	open {_inv} to {_p}


function commandOpGui(p: player):
