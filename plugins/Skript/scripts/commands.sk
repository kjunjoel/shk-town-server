	set slot 5 of {_inv} to {_item}

	set {_item} to "shkworld_kr" parsed as offlineplayer's skull named "&bSHK WORLD &f| &e&l친구" with custom model data 95 with lore "&7└ 친구에 대해서 알아봅니다."
