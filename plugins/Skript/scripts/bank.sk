options:
    # 접두사
    prefix: <##bd3995>&l[은행]&f

    # 은행
    은행총재: 은행총재
    은행부총재: 은행부총재
    은행감사: 은행감사
    은행국장: 은행국장
    은행부국장: 은행부국장
    은행부장: 은행부장
    은행과장: 은행과장
    은행원: 은행원

    # 럭펌 노드명
    shkbankAdmin: shkbank.admin # 은행총재 ~ 은행부총재
    shkbankUser: shkbank.user # 은행총재 ~ 은행원

# 변수
# {shkbank.user::*}                           | 은행 소속 공무원 목록
# {shkbank.user.%uuid of player%.class}       | 은행 소속 직급 목록

command /은행 [<text>] [<offlineplayer>] [<text>]:
    permission: {@shkbankAdmin}
    permission message: {@prefix} 해당 명령어를 사용할 권한이 없습니다.
    trigger:
        if arg 1 is "목록":
            if {shkbank.user::*} is not set:
                send "{@prefix} 은행 소속 공무원이 존재하지 않습니다."
                stop
            send "{@prefix} 은행 소속 공무원 목록은 아래와 같습니다."
            set {_ind} to 1
            set {_list::*} to {shkbank.user::*}
            loop "{@은행총재}", "{@은행부총재}", "{@은행감사}", "{@은행국장}", "{@은행부국장}", "{@은행부장}", "{@은행과장}" and "{@은행원}":
                loop {_list::*}:
                    if {shkbank.user.%uuid of loop-value-2%.class} is loop-value-1:
                        send "{@prefix} %{_ind}%. %loop-value-2% (%{shkbank.user.%uuid of loop-value-2%.class}%, %{bank.account::%uuid of loop-value-2%}%)"
                        add 1 to {_ind}
        
        else if arg 1 is "채용":
            if arg 2 is not set:
                send "{@prefix} 해당 플레이어를 찾을 수 없습니다."
                stop
            loop {shkbank.user::*}:
                if loop-value is arg-2:
                    send "{@prefix} 해당 플레이어는 이미 은행에 소속되어 있습니다."
                    stop
            if arg-2 has permission "farmer.user":
                if farmPrice(arg-2) > 0:
                    send "{@prefix} &f농부는 농지 판매 후 채용할 수 있습니다." to player
                    stop
            if arg 3 is not set:
                send "{@prefix} 직급을 입력해주세요."
                stop
            if arg 3 is "{@은행총재}" or "{@은행부총재}" or "{@은행감사}" or "{@은행국장}" or "{@은행부국장}" or "{@은행부장}" or "{@은행과장}" or "{@은행원}":
                if group of player is "{@은행총재}":
                    if arg 3 is "{@은행총재}":
                        send "{@prefix} 자신과 같거나 상위 직급은 채용할 수 없습니다."
                        stop
                else if group of player is "{@은행부총재}":
                    if arg 3 is "{@은행총재}" or "{@은행부총재}":
                        send "{@prefix} 자신과 같거나 상위 직급은 채용할 수 없습니다."
                        stop
                add arg-2 to {shkbank.user::*}
                execute console command "lp user %arg-2% parent set default"
                execute console command "lp user %arg-2% parent add %arg-3%"
                send "{@prefix} &6%arg-2%&f님이 은행 소속 &e%arg-3%&f(으)로 채용되었습니다. &7(담당자 | %player%)" to all players
                set {shkbank.user.%uuid of arg-2%.class} to arg-3
                stop
            else:
                send "{@prefix} 올바른 직급명을 입력해주세요."
                stop
        
        else if arg 1 is "해임":
            if arg 2 is not set:
                send "{@prefix} 해당 플레이어를 찾을 수 없습니다."
                stop
            set {_state} to false
            loop {shkbank.user::*}:
                if loop-value is arg-2:
                    set {_state} to true
            if {_state} is false:
                send "{@prefix} 해당 플레이어는 은행 소속이 공무원이 아닙니다."
                stop
            if group of player is "{@은행총재}":
                if {shkbank.user.%uuid of arg-2%.class} is "{@은행총재}":
                    send "{@prefix} 자신과 같거나 상위 직급은 해임할 수 없습니다."
                    stop
            else if group of player is "{@은행부총재}":
                if {shkbank.user.%uuid of arg-2%.class} is "{@은행총재}" or "{@은행부총재}":
                    send "{@prefix} 자신과 같거나 상위 직급은 해임할 수 없습니다."
                    stop
            remove arg-2 from {shkbank.user::*}
            execute console command "lp user %arg-2% parent remove %{shkbank.user.%uuid of arg-2%.class}%"
            delete {shkbank.user.%uuid of arg-2%.class}
            send "{@prefix} &6%arg-2%&f님이 은행 소속 공무원에서 해임되었습니다. &7(담당자 | %player%)" to all players
            stop
        
        else:
            send "{@prefix} /은행 목록 &8&l| &f은행 소속 공무원 목록을 확인합니다."
            send "{@prefix} /은행 채용 [플레이어명] [직급] &8&l| &f플레이어를 직급으로 채용합니다."
            send "{@prefix} /은행 해임 [플레이어명] &8&l| &f플레이어를 은행에서 해임합니다."
            send "{@prefix} /은행공지 [내용] &8&l| &f[내용]을 공지합니다."
            stop


command /은행공지 [<text>]:
    permission: {@shkbankAdmin}
    permission message: {@prefix} 해당 명령어를 사용할 권한이 없습니다.
    trigger:
        if arg 1 is not set:
            send "{@prefix} 공지 내용을 입력해주세요."
            stop
        send "" to all players
        send "{@prefix} &l%arg-1% &7(작성자 | %player%)" to all players
        send "" to all players
        play sound "ENTITY_PLAYER_LEVELUP" with volume 0.5 to all players
        stop

options:
    @: &6[&e&l예산&6]&f

    # 로그
    dir: plugins/Skript/data/logs/budget

# 변수
# {budget::%name%}  | 기관 예산

function budgetAdd(name: text, p: offlineplayer, n: number, t: text):
    add {_n} to {budget::%{_name}%}
    balanceRemove({_p}, {_n}, "Budget") if {_t} isn't "OP"
    if {_t} is "OP":
        sync insert "%now formatted as "yyyyMMdd HHmmss"% Add 서버 %{_n}% -> %{budget::%{_name}%}%" at line 1 of file path "{@dir}/%{_name}%.txt"
    else if {_t} is "Tax":
        sync insert "%now formatted as "yyyyMMdd HHmmss"% Add 세금(일반직) %{_n}% -> %{budget::%{_name}%}%" at line 1 of file path "{@dir}/%{_name}%.txt"
    else if {_t} is "국고기부":
        sync insert "%now formatted as "yyyyMMdd HHmmss"% Add %{_p}%(국고기부) %{_n}% -> %{budget::%{_name}%}%" at line 1 of file path "{@dir}/%{_name}%.txt"
    else if {_t} is "인지대기부":
        sync insert "%now formatted as "yyyyMMdd HHmmss"% Add %{_p}%(인지대기부) %{_n}% -> %{budget::%{_name}%}%" at line 1 of file path "{@dir}/%{_name}%.txt"
    else if {_t} is "국고입금":
        sync insert "%now formatted as "yyyyMMdd HHmmss"% Add %{_p}%(국고입금) %{_n}% -> %{budget::%{_name}%}%" at line 1 of file path "{@dir}/%{_name}%.txt"
    else if {_t} is "인지대입금":
        sync insert "%now formatted as "yyyyMMdd HHmmss"% Add %{_p}%(인지대입금) %{_n}% -> %{budget::%{_name}%}%" at line 1 of file path "{@dir}/%{_name}%.txt"
    else if {_t} is "등록금입금":
        sync insert "%now formatted as "yyyyMMdd HHmmss"% Add %{_p}%(등록금입금) %{_n}% -> %{budget::%{_name}%}%" at line 1 of file path "{@dir}/%{_name}%.txt"
    else:
        sync insert "%now formatted as "yyyyMMdd HHmmss"% Add %{_p}% %{_n}% -> %{budget::%{_name}%}%" at line 1 of file path "{@dir}/%{_name}%.txt"

function budgetRemove(name: text, p: offlineplayer, n: number, t: text):
    remove {_n} from {budget::%{_name}%}
    if {_t} isn't "Salary":
        if {_t} isn't "OP":
            balanceAdd({_p}, {_n}, "Budget")
    if {_t} is "OP":
        sync insert "%now formatted as "yyyyMMdd HHmmss"% Remove 서버 %{_n}% -> %{budget::%{_name}%}%" at line 1 of file path "{@dir}/%{_name}%.txt"
    else if {_t} is "Salary":
        sync insert "%now formatted as "yyyyMMdd HHmmss"% Remove %{_p}%(일급) %{_n}% -> %{budget::%{_name}%}%" at line 1 of file path "{@dir}/%{_name}%.txt"
    else if {_t} is "국고출금":
        sync insert "%now formatted as "yyyyMMdd HHmmss"% Remove %{_p}%(국고출금) %{_n}% -> %{budget::%{_name}%}%" at line 1 of file path "{@dir}/%{_name}%.txt"
    else if {_t} is "인지대출금":
        sync insert "%now formatted as "yyyyMMdd HHmmss"% Remove %{_p}%(인지대출금) %{_n}% -> %{budget::%{_name}%}%" at line 1 of file path "{@dir}/%{_name}%.txt"
    else if {_t} is "등록금출금":
        sync insert "%now formatted as "yyyyMMdd HHmmss"% Add %{_p}%(등록금출금) %{_n}% -> %{budget::%{_name}%}%" at line 1 of file path "{@dir}/%{_name}%.txt"
    else if {_t} contains "테러실패":
        sync insert "%now formatted as "yyyyMMdd HHmmss"% Remove %{_p}%(%{_t}%) %{_n}% -> %{budget::%{_name}%}%" at line 1 of file path "{@dir}/%{_name}%.txt"
    else:
        sync insert "%now formatted as "yyyyMMdd HHmmss"% Remove %{_p}% %{_n}% -> %{budget::%{_name}%}%" at line 1 of file path "{@dir}/%{_name}%.txt"

function budgetList(p: player, name: text, page: number, t: text):
    set {_file::*} to content of file path "{@dir}/%{_name}%.txt"
    send "&6예산 입출금 기록 (%now%)" to {_p}
    if {_file::*} isn't set:
        send "&4예산 입출금 기록을 찾을 수 없음." to {_p}
        stop
    set {_max} to round up (size of {_file::*} / 10)
    send " &e---- &6기록 &e-- &6페이지 &c%{_page}%&6/&c%{_max}% &e----" to {_p}
    set {_ind} to 0
    loop {_file::*}:
        add 1 to {_ind}
        if {_ind} is between (({_page}-1)*10+1) and ({_page}*10):
            set {_list::*} to loop-value split by " "
            set {_money} to {_list::5} parsed as number
            set {_left} to {_list::7} parsed as number
            if {_list::3} is "Add":
                set {_type} to "입금"
            else if {_list::3} is "Remove":
                set {_type} to "출금"
            send "&7[%{_ind}%] &f%{_list::1}% | %{_list::4}% | %moneyDigit({_money})%원 %{_type}% | 잔액 %moneyDigit({_left})%원" to {_p}
    if {_page} < {_max}:
        if {_t} is "None":
            send "&c/예산 %{_name}% 확인 %{_page}+1%&6을(를) 입력하여 다음 페이지를 읽으세요." to {_p}
        else if {_t} is "OP":
            send "&c/budget get %{_name}% %{_page}+1%&6을(를) 입력하여 다음 페이지를 읽으세요." to {_p}

function budgetBankList(p: player, page: number):
    set {_file::*} to content of file path "{@dir}/국고.txt"
    send "&6예산 입출금 기록 (%now%)" to {_p}
