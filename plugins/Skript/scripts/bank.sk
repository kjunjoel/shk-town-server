            send "{@@} /등록금 출금 [금액] &8&l| &f금액만큼 등록금에서 예산을 출금합니다." if player has permission "univ.admin"
            stop

command /budget [<text>] [<text>] [<number>]:
    permission: op.user
    trigger:
        if arg-1 is "get":
            if arg-2 isn't set:
                send "{@@} 기관명을 입력해주세요."
                stop
            loop "시청", "의회", "대법원", "검찰청", "경찰청", "대학교", "특허청", "문화방송원", "국고", "인지대", "감사원", "등록금" and "은행":
                if arg-2 is loop-value:
                    set {_temp} to true
            if {_temp} isn't set:
                send "{@@} 올바른 기관명을 입력해주세요."
                stop
            set {_page} to arg-3
            if {_page} isn't set:
                set {_page} to 1
            send "{@@} 현재 &a%arg-2%&f의 예산은 &6%moneyDigit({budget::%arg-2%})%&f원입니다."
            budgetList(player, arg-2, {_page}, "OP")
    
        else if arg-1 is "give":
            if arg-2 isn't set:
                send "{@@} 기관명을 입력해주세요."
                stop
            loop "시청", "의회", "대법원", "검찰청", "경찰청", "대학교", "특허청", "문화방송원", "국고", "인지대", "감사원", "등록금" and "은행":
                if arg-2 is loop-value:
                    set {_temp} to true
            if {_temp} isn't set:
                send "{@@} 올바른 기관명을 입력해주세요."
                stop
            if arg-3 isn't set:
                send "{@@} 추가할 금액을 입력해주세요."
                stop
            budgetAdd(arg-2, player, arg-3, "OP")
            send "{@@} &6%moneyDigit(arg-3)%&f원을 추가하였습니다. 현재 &a%arg-2%&f의 예산은 &6%moneyDigit({budget::%arg-2%})%&f원입니다."

        else if arg-1 is "take":
            if arg-2 isn't set:
                send "{@@} 기관명을 입력해주세요."
                stop
            loop "시청", "의회", "대법원", "검찰청", "경찰청", "대학교", "특허청", "문화방송원", "국고", "인지대", "감사원", "등록금" and "은행":
                if arg-2 is loop-value:
                    set {_temp} to true
            if {_temp} isn't set:
                send "{@@} 올바른 기관명을 입력해주세요."
                stop
            if arg-3 isn't set:
                send "{@@} 삭제할 금액을 입력해주세요."
                stop
            if arg-3 > {budget::%arg-2%}:
                send "{@@} 삭제할 금액은 예산보다 클 수 없습니다."
                stop
            budgetRemove(arg-2, player, arg-3, "OP")
            send "{@@} &6%moneyDigit(arg-3)%&f원을 삭제하였습니다. 현재 &a%arg-2%&f의 예산은 &6%moneyDigit({budget::%arg-2%})%&f원입니다."

        else:
            send "{@@} /budget get [이름] [페이지] &8&l| &f기관의 예산 입출금 기록을 확인합니다."
            send "{@@} /budget give [이름] [금액] &8&l| &f금액만큼 기관의 예산을 추가합니다."
            send "{@@} /budget take [이름] [금액] &8&l| &f금액만큼 기관의 예산을 삭제합니다."

options:
    # 럭펌 그룹명

    # 시청       
    시청장: 시청장      
    부시청장: 부시청장       
    관리관: 관리관          
    이사관: 이사관         
    부이사관: 부이사관
    서기관: 서기관
    사무관: 사무관
    주사: 주사
    주사보: 주사보
    서기: 서기
    서기보: 서기보

    # 경찰
    경찰청장: 경찰청장
    치안정감: 치안정감
    치안감: 치안감
    경무관: 경무관
    총경: 총경
    경정: 경정
    경감: 경감
    경위: 경위
    경사: 경사
    경장: 경장
    순경: 순경
    
    # 검찰
    검찰총장: 검찰총장
    검사장: 검사장
    차장검사: 차장검사
    부장검사: 부장검사
    부부장검사: 부부장검사
    검사: 검사

    # 대학교
    총장: 총장
    부총장: 부총장
    학과장: 학과장
    교수: 교수
    조교수: 조교수
    전임교원: 전임교원

    # 문화방송원
    원장: 문화방송원원장
    부원장: 문화방송원부원장
    차장: 문화방송원차장
    부장: 문화방송원부장
    부부장: 문화방송원부부장
    부원: 문화방송원부원
    인턴: 문화방송원인턴

    # 의회
    의장: 의장
    의원: 의원

    # 법원
    대법원장: 대법원장
    대법관: 대법관
    수석부장판사: 수석부장판사
    부장판사: 부장판사
    판사: 판사
    판사시보: 판사시보

    # 헌재
    헌법재판소장: 헌법재판소장
    헌법재판관: 헌법재판관

    # 특허청
    특허청장: 특허청장
    특허청차장: 특허청차장

    #감사원
    감사위원: 감사위원

    #공백
    공백: BLANK

    #prefix
    !: &f[ §x§1§a§6§7§f§bO§x§2§b§7§5§f§7f§x§3§d§8§2§f§3f§x§4§e§9§0§e§fi§x§5§f§9§e§e§bc§x§7§1§a§b§e§7e §x§8§2§b§9§e§4S§x§9§4§c§6§e§0a§x§a§5§d§4§d§cl§x§b§6§e§2§d§8a§x§c§8§e§f§d§4r§x§d§9§f§d§d§0y &f]

    dir: plugins/Skript/data/logs/tax/%now formatted as "yyyy-MM-dd"%.txt

function OfficeSalaryPrice(p: player) :: number:
    if group of {_p} is "{@의장}" or "{@대법원장}":
        return 3100000
    else if group of {_p} is "{@공백}":
        return 2900000
    else if group of {_p} is "{@시청장}" or "{@은행총재}" or "{@경찰청장}" or "{@검찰총장}" or "{@총장}" or "{@원장}" or "{@대법관}":
        return 2700000
    else if group of {_p} is "{@부시청장}" or "{@은행부총재}" or "{@치안정감}" or "{@검사장}" or "{@부총장}" or "{@부원장}":
        return 2500000
    else if group of {_p} is "{@관리관}" or "{@경무관}" or "{@부장검사}" or "{@차장}" or "{@수석부장판사}" or "{@특허청장}":
        return 2300000
    else if group of {_p} is "{@이사관}" or "{@은행국장}" or "{@치안감}":
        return 2100000
    else if group of {_p} is "{@부이사관}" or "{@총경}" or "{@부부장검사}" or "{@학과장}" or "{@부장}" or "{@부장판사}" or "{@특허청차장}":
        return 1900000
    else if group of {_p} is "{@서기관}" or "{@경정}" or "{@교수}":
        return 1700000
    else if group of {_p} is "{@사무관}" or "{@은행부국장}" or "{@경감}" or "{@검사}" or "{@조교수}" or "{@부부장}" or "{@판사}":
        return 1500000
    else if group of {_p} is "{@주사}" or "{@경위}":
        return 1300000
    else if group of {_p} is "{@주사보}" or "{@은행부장}" or "{@경사}" or "{@부원}":
        return 1100000
    else if group of {_p} is "{@서기}" or "{@경장}" or "{@판사시보}":
        return 900000
    else if group of {_p} is "{@서기보}" or "{@은행원}" or "{@순경}" or "{@전임교원}" or "{@인턴}":
        return 700000
    return 0

command /공무원일급 [<text>] [<text>]:
    trigger:
        stop
        if arg-1 isn't set:
            send "{@!} 기관명을 입력해주세요."
            send "     &7└ 시청, 의회, 대법원, 검찰청, 경찰청, 대학교, 문화방송원, 은행, 특허청, 감사원"
            stop
        loop "시청", "의회", "대법원", "검찰청", "경찰청", "대학교", "특허청", "문화방송원", "감사원", and "은행":
            if arg-1 is loop-value:
                if arg-1 is "시청":
                    if player doesn't have permission "city.user":
                        send "{@!} 당신은 &d&l시청&f의 일급을 받을 권한이 없습니다."
                        stop

                else if arg-1 is "의회":
                    if player doesn't have permission "congress.user":
                        send "{@!} 당신은 &e&l의회&f의 일급을 받을 권한이 없습니다."
                        stop

                else if arg-1 is "대법원":
                    if player doesn't have permission "court.user":
                        send "{@!} 당신은 &c&l대법원&f의 일급을 받을 권한이 없습니다."
                        stop

                else if arg-1 is "검찰청":
                    if player doesn't have permission "prose.user":
                        send "{@!} 당신은 &9&l검찰청&f의 일급을 받을 권한이 없습니다."
                        stop


                else if arg-1 is "경찰청":
                    if player doesn't have permission "police.user":
                        send "{@!} 당신은 &b&l경찰청&f의 일급을 받을 권한이 없습니다."
                        stop


                else if arg-1 is "대학교":
                    if player doesn't have permission "univ.user":
                        send "{@!} 당신은 &a&l대학교&f의 일급을 받을 권한이 없습니다."
                        stop


                else if arg-1 is "문화방송원":
                    if player doesn't have permission "culbro.user":
                        send "{@!} 당신은 &3&l문화방송원&f의 일급을 받을 권한이 없습니다."
                        stop


                else if arg-1 is "은행":
                    if player doesn't have permission "shkbank.user":
                        send "{@!} 당신은 &e&l상어은행&f의 일급을 받을 권한이 없습니다."
                        stop


                else if arg-1 is "헌법재판소":
                    if player doesn't have permission "ccourt.user":
                        send "{@!} 당신은 &6&l헌법&c재판소&f의 일급을 받을 권한이 없습니다."
                        stop

                else if arg-1 is "감사원":
                    if player doesn't have permission "bai.user":
                        send "{@!} 당신은 &5&l감사원&f의 일급을 받을 권한이 없습니다."
                        stop


                else if arg-1 is "특허청":
                    if player doesn't have permission "kipo.user":
                        send "{@!} 당신은 &9&l특&1&l허&b청&f의 일급을 받을 권한이 없습니다."
                        stop
                set {_temp} to true

        if {_temp} isn't set:
            send "{@!} 올바른 기관명을 입력해주세요."
            send "     &7└ 시청, 의회, 대법원, 검찰청, 경찰청, 대학교, 문화방송원, 은행, 특허청, 감사원"
            stop

        if arg-2 is "받기":
            if {office.salary::%uuid of player%} is true:
                send title "&6&l[&6&l&o!&6&l]" with subtitle "&7일급을 이미 받으셨습니다." for 2 seconds
                stop
            set {_price} to OfficeSalaryPrice(player)
            if {_price} < 0:
                send title "&6&l[&6&l&o!&6&l]" with subtitle "&7일급이 설정되지 않았습니다." for 2 seconds
                stop
            set {_tax} to {_price}*0.1
            add {_tax} to {job.tax}
            set {_real} to {_price}*0.9
            create file "{@dir}" if file "{@dir}" doesn't exist
            

            if {_real} > {budget::%arg-1%}:
                send "{@@} 예산이 부족하여 일급을 받을 수 없습니다."
                stop

            write "%now formatted as "yyyy-MM-dd HH:mm:ss"% %player% %{_tax}% -> %{job.tax}%" at line (size of file contents of "{@dir}")+1 to file "{@dir}"
            play sound "ENTITY_PLAYER_LEVELUP" with volume 0.4 to player

            budgetRemove(arg-1, player, {_real}, "None")
            balanceAdd(player, {_real}, "%arg-1%OfficeSalary")
            send title "&e&l%moneyDigit({_real})%원" with subtitle "&7일급을 지급받았습니다." for 2 seconds
            send " {@!} &bSHK WORLD &a공무원 &f급여 명세서"
            send " {@!} &f성명: &e%player% &f| &f지급일: %now formatted as "yyyy.MM.dd"%"
            send " {@!} &f&l임금항목&f: 기본급 &a%moneyDigit({_price})%&f원"
            send " {@!} &f&l공제내역&f: 소득세 &a%moneyDigit({_tax})%&f원"
            send " {@!} &f&l실지급액&f: &a%moneyDigit({_real})%&f원"
            stop


            
        else:
            send " &7&l&m──────────────────────────────────────────────────"
            send "   {@!} &f/공무원일급 [기관] 받기 &7- 자신의 직업 일급을 지급받습니다."
            send "       &6└ &f%player's group% &7일급을 받습니다."
            send " &7&l&m──────────────────────────────────────────────────"
            stop

command /office_salary_reset [<offlineplayer>]:
    permission: op.user
    permission message: &c명령어를 사용할 권한이 없습니다.
    trigger:
        if arg-1 is "all":
            delete {office.salary::*}
            send " {@!} &e모든 플레이어&f의 공무원 일급 지급 데이터를 정상적으로 초기화하였습니다."
            stop
        delete {office.salary::%uuid of arg-1%}
        send " {@!} &e%arg-1%&f님의 공무원 일급 지급 데이터를 정상적으로 초기화하였습니다."