function budgetUnivList(p: player, page: number):
    set {_file::*} to content of file path "{@dir}/등록금.txt"
    send "&6예산 입출금 기록 (%now%)" to {_p}
    if {_file::*} isn't set:
        send "&4예산 입출금 기록을 찾을 수 없음." to {_p}
        stop
