    if {_page} < {_max}:
        send "&c/국고 확인 %{_page}+1%&6을(를) 입력하여 다음 페이지를 읽으세요." to {_p}

function budgetCourtList(p: player, page: number):
    set {_file::*} to content of file path "{@dir}/인지대.txt"
    send "&6예산 입출금 기록 (%now%)" to {_p}
    if {_file::*} isn't set:
        send "&4예산 입출금 기록을 찾을 수 없음." to {_p}
        stop
