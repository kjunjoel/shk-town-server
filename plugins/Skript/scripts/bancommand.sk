on command "/spin":
    if player has permission "op.user":
        stop
    cancel event
    send "&c사용하실 수 없는 명령어입니다."

on command "/gspin":
    if player has permission "op.user":
        stop
    cancel event
    send "&c사용하실 수 없는 명령어입니다."

