command /그림저장 [<text>]:
    trigger:
        if arg-1 isn't set:
            send "[ &6&l!&f] 그림 이름을 입력해주세요."
            stop
        make player run command "art save %arg-1%" as op

on command "/art":
    if player has permission "op.user":
        stop
    cancel event
    send "&c사용하실 수 없는 명령어입니다."

