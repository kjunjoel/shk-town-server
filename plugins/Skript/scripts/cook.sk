import:
    org.bukkit.event.player.PlayerInteractEvent
    org.bukkit.Material

options:
    prefix: &f[&e서촌&b&l식자재&a마트&f]
    gui: &e서촌&b&l식자재&a마트&f
    data: plugins/Skript/data/cook/market.txt
    
# 변수
# {cook.stock::%item type%.%custom model data%}  | item type & custom model data의 재고
# {cook.volume::%item type%.%custom model data%} | item type & custom model data의 현재 재고(거래량)
# {cook.close::%item.type%.%custom model data%}  | item type & custom model data의 장마감
# {cook.vi::%item.type%.%custom model data%}     | item type & custom model data의 VI 발동 남은 시간 (minute)
# {cook.npc::%name%}                             | name의 NPC 이름

on load:
    stop
    set {_file::*} to content of file path "plugins/Skript/data/cook/ia.txt"
    loop {_file::*}:
        set {_data::*} to loop-value split by " "
        replace all "_" in {_data::1} with " "
        set {cook.ia::%{_data::1}%} to {_data::2}

function cookItem(i: item, price: integer, option: text) :: item:
    set {_item} to {_i}
    add "&f" to lore of {_i}
    if {_price} is 0:
        add "&7구매할 수 없음" to lore of {_i}
    else:
        add "&b현재 &f가격: &e&l%moneyDigit({_price})%&e원" to lore of {_i}
    add "&f" to lore of {_i}
    add "&6좌클릭&f하여 1개 &6구매" to lore of {_i} if {_option} isn't "purchase"
    add "&a우클릭&f하여 1개 &a판매" to lore of {_i}
    add "&6SHIFT + 좌클릭&f하여 64개 &6구매" to lore of {_i} if {_option} isn't "purchase"
    add "&aSHIFT + 우클릭&f하여 모두 &a판매" to lore of {_i}
    return {_i}

function cookPrice(i: item) :: integer:
    set {_stock} to {cook.stock::%type of {_i}%.%custom model data of {_i}%}
    if {_stock} isn't set:
        return 0
    if type of {_i} is seed or pumpkin seed or melon seed or beetroot seed:
        set {_price} to round down (200*({_stock}^(-0.1))+(200/{_stock}))
    else:
        set {_price} to round down (1000000000 / {_stock})
    return {_price}

function cookGUI1(p: player, option: text):
    set {_inv} to chest inventory with 5 rows named "{@gui} - 과일 및 기타"
    set slot 10 of {_inv} to cookItem(honey bottle, 1200, {_option})
    set slot 11 of {_inv} to cookItem(brown mushroom, 1500, {_option})
    set slot 12 of {_inv} to cookItem(crimson fungus, 1500, {_option})
    set slot 13 of {_inv} to cookItem(warped fungus, 1500, {_option})
    set slot 14 of {_inv} to cookItem(ice block, 200, {_option})
    set slot 15 of {_inv} to cookItem(sugar, 300, {_option})
    set slot 16 of {_inv} to cookItem(cocoa bean, cookPrice(cocoa bean), {_option})
    set slot 29 of {_inv} to cookItem(cooked pork with custom model data 10033 named "&f양파", cookPrice(cooked pork with custom model data 10033), {_option})
    set slot 30 of {_inv} to cookItem(cooked pork with custom model data 10028 named "&f토마토", cookPrice(cooked pork with custom model data 10028), {_option})
    set slot 31 of {_inv} to cookItem(cooked pork with custom model data 10035 named "&f양배추", cookPrice(cooked pork with custom model data 10035), {_option})
    set slot 32 of {_inv} to cookItem(paper with custom model data 10034 named "&f벼", cookPrice(paper with custom model data 10034), {_option})
    set slot 33 of {_inv} to cookItem(apple, 750, {_option})
    open {_inv} to {_p}

