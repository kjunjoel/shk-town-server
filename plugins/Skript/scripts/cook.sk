    set slot 19 of {_inv} to cookItem(bowl, 157, {_option})
    set slot 20 of {_inv} to cookItem(empty bottle, 52, {_option})
    set slot 21 of {_inv} to cookItem(bucket, 114, {_option})
    set slot 23 of {_inv} to cookItem(paper with custom model data 10007 named "&f난로", 1430000, {_option})
    set slot 24 of {_inv} to cookItem(paper with custom model data 10031 named "&f조리용 냄비", 518990, {_option})
    set slot 25 of {_inv} to cookItem(paper with custom model data 10030 named "&f프라이팬", 481050, {_option})
    set slot 26 of {_inv} to cookItem(paper with custom model data 10036 named "&f도마", 255900, {_option})
    set slot 38 of {_inv} to cookItem(wooden sword with custom model data 10001 named "&f부싯돌 식칼", 144100, {_option})
    set slot 39 of {_inv} to cookItem(wooden sword with custom model data 10004 named "&f철 식칼", 250000, {_option})
    set slot 40 of {_inv} to cookItem(wooden sword with custom model data 10003 named "&f금 식칼", 38400, {_option})
    set slot 41 of {_inv} to cookItem(wooden sword with custom model data 10002 named "&f다이아몬드 식칼", 1248800, {_option})
    set slot 42 of {_inv} to cookItem(wooden sword with custom model data 10000 named "&f네더라이트 식칼", 1421700, {_option})
