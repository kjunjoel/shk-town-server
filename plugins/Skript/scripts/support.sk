        send "> <##87CEEB>&lSVIP+ &e&l%player%님&f이 서버에서 퇴장하셨습니다! <" to all players


command /누적후원보상 <offlineplayer> <integer>:
    permission: op.user
    trigger:
        set {_taxi} to paper named "&6택시 &f호출권" with lore "&7스마트폰에서 택시를 호출할 수 있습니다." and "&7거래가 불가능한 아이템입니다."
        set {_name} to name tag named "&f커스텀 칭호권" with lore "&7사용하려면 관리자 호출" and "&7거래가 불가능한 아이템입니다."
        set {_support} to book named "&f[ <##87CEFA>SUPPORT &f]" with lore "&7우클릭하여 칭호를 획득합니다."
        if arg-2 is 1:
            itemGive(arg-1, {_taxi}, 10, "Support")
        if arg-2 is 3:
            execute player command "lp user %arg-1% permission set SUPPORT.user"
            set {_prefix} to book named "&f[ <##87CEFA>SUPPORT &f]" with lore "&7우클릭하여 칭호를 획득합니다."
            itemGive(arg-1, {_taxi}, 20, "Support")
            itemGive(arg-1, {_prefix}, 1, "Support")
        if arg-2 is 5:
            execute player command "lp user %arg-1% permission set VIP.user"
            set {_prefix} to book named "&f[ <##87CEFA>&lVIP &f]" with lore "&7우클릭하여 칭호를 획득합니다."
            itemGive(arg-1, {_taxi}, 20, "Support")
            itemGive(arg-1, {_name}, 1, "Support")
            itemGive(arg-1, {_prefix}, 1, "Support")
        if arg-2 is 10:
            execute player command "lp user %arg-1% permission set VIP+.user"
            set {_prefix} to book named "&f[ <##87CEFA>&lVIP+ &f]" with lore "&7우클릭하여 칭호를 획득합니다."
            itemGive(arg-1, {_taxi}, 50, "Support")
            itemGive(arg-1, {_name}, 1, "Support")
            itemGive(arg-1, {_prefix}, 1, "Support")
        if arg-2 is 20:
            execute player command "lp user %arg-1% permission set SVIP.user"
            set {_prefix} to book named "&f[ <##87CEFA>&lSVIP &f]" with lore "&7우클릭하여 칭호를 획득합니다."
            itemGive(arg-1, {_taxi}, 100, "Support")
            itemGive(arg-1, {_name}, 1, "Support")
            itemGive(arg-1, {_prefix}, 1, "Support")
        if arg-2 is 30:
            execute player command "lp user %arg-1% permission set SVIP+.user"
            set {_prefix} to book named "&f[ <##87CEFA>&lSVIP+ &f]" with lore "&7우클릭하여 칭호를 획득합니다."
            itemGive(arg-1, {_taxi}, 100, "Support")
            itemGive(arg-1, {_name}, 1, "Support")
            itemGive(arg-1, {_prefix}, 1, "Support")
            send formatted "[ &6&l! &f] <url:https://discord.gg/dvr2W7EeT7>&e&l여기<reset>&f를 눌러 &a빌딩 구매소&f로 이동합니다." to arg-1
        if arg-2 is 50:
            execute player command "lp user %arg-1% permission set MVP.user"
            set {_prefix} to book named "&f[ <##87CEFA>&lMVP &f]" with lore "&7우클릭하여 칭호를 획득합니다."
            itemGive(arg-1, {_taxi}, 200, "Support")
            itemGive(arg-1, {_name}, 1, "Support")
            itemGive(arg-1, {_prefix}, 1, "Support")
        if arg-2 is 100:
            execute player command "lp user %arg-1% permission set MVP+.user"
            set {_prefix} to book named "&f[ <##87CEFA>&lMVP+ &f]" with lore "&7우클릭하여 칭호를 획득합니다."
            itemGive(arg-1, {_taxi}, 500, "Support")
            itemGive(arg-1, {_name}, 1, "Support")
            itemGive(arg-1, {_prefix}, 1, "Support")
        if arg-2 is 150:
            execute player command "lp user %arg-1% permission set RVIP.user"
            set {_prefix} to book named "&f[ <##87CEFA>&lRVIP &f]" with lore "&7우클릭하여 칭호를 획득합니다."
            itemGive(arg-1, {_taxi}, 1000, "Support")
            itemGive(arg-1, {_name}, 2, "Support")
            itemGive(arg-1, {_prefix}, 1, "Support")
        if arg-2 is 200:
            execute player command "lp user %arg-1% permission set RVIP+.user"
            set {_prefix} to book named "&f[ <##87CEFA>&lRVIP+ &f]" with lore "&7우클릭하여 칭호를 획득합니다."
            itemGive(arg-1, {_name}, 2, "Support")
            itemGive(arg-1, {_prefix}, 1, "Support")
        send "[ &6&l! &f] &a%arg-1%님&f에게 &e%moneyDigit(arg-2 * 10000)%원 &f누적 후원보상을 지급했습니다."
        send "[ &6&l! &f] &e%moneyDigit(arg-2 * 10000)%원 &f누적 후원보상을 지급받았습니다." to arg-1
        