    else if uuid of player is "bac2bca2-c558-4f5d-b59a-6549c5d60882": # Hood_S (미설정)
        send "> <##87CEEB>&lMVP+ &e&l%player%님&f이 서버에서 퇴장하셨습니다! <" to all players
    
    else if player has permission "MVP.user":
        {list.admin::*} doesn't contain "%player%"
