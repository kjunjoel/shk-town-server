on quit:
    if uuid of player is "029189db-abe3-43ac-a6ec-0bf4b216e278": # MaWangNim
        send "&c&l악마가 봉인되었습니다." to all players
    else if uuid of player is "253902dc-2287-4697-8472-6fa905916797": # kosown
        send "&e&l귀하신 소은님께서 퇴장하셨습니다" to all players
    else if uuid of player is "46c08e51-63a3-4085-8a98-45a1676cecc5": # hehekong (미설정)
        send "<##D4B1FD>&lBye~ Kong!"
    else if uuid of player is "67f3b56d-7f77-4325-974b-ff1d6aceef79": # CRC_IDs_KCB
        send "&b부디 그의 재산을 상장폐지로부터 보호받게 해주소서..." to all players
