on inventory click:
    if {gui.%uuid of player%::WeddingNPC} is true:
        cancel event
        if clicked slot is 11:
            close player's inventory
            make player run command "job_change_with_permission_Lantum 주례사" as op
            stop
        if clicked slot is 15:
            close player's inventory
            send "{@prefix} 다른 직업을 선택해볼까요?"
            stop

    else if {gui.%uuid of player%::CookNPC} is true:
