        set slot 13 of {_inv} to clock named "&a직업 변경 &f쿨타임 여부: &a✔" with lore "&7내일 오전 0시에 변경이 가능합니다."
    else if {job.change::%uuid of {_p}%} is not true:
        set slot 13 of {_inv} to clock named "&a직업 변경 &f쿨타임 여부: &c✖" with lore "&7지금 직업 변경이 가능합니다."
    set slot 15 of {_inv} to {vote.icon::X} named "&c&l닫기" with lore "&a좌클릭&7하여 직업 변경창을 닫습니다."
    set slot 30 of {_inv} to {job.icon::1} named "&6&l명령어" with lore "&7/요리사상가"
    set slot 32 of {_inv} to {job.icon::2} named "&6&l직업 설명" with lore "&7요리사는 음식을 만들어 유저들에게 판매합니다.", "&7모든 요리는 요리사만 제작이 가능하며 요리를 위해서는 요리 도구가 필요합니다.", " ", "&7요리 도구가 없는 요리사는 공용주방에서 별도로 준비된 요리 도구들로 요리하며", "&7요리사와 관련된 것은 서촌식자재마트에서 구매 가능합니다.", "&f&m&l━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━", "&7요리사 일급(세전): &f₩ &e400,000", "&7요리사 일급(세후): &f₩ &a360,000", " "
    open {_inv} to {_p}

function RobNPC(p: player):
    set {_inv} to chest inventory with 5 rows named "&6&l강도 &f직업 변경"
    set slot 11 of {_inv} to {vote.icon::O} named "&6&l강도&f로 직업 변경" with lore "&a좌클릭&7하여 직업을 변경합니다."
