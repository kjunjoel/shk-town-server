    else if {job.change::%uuid of {_p}%} is not true:
        set slot 13 of {_inv} to clock named "&a직업 변경 &f쿨타임 여부: &c✖" with lore "&7지금 직업 변경이 가능합니다."
    set slot 15 of {_inv} to {vote.icon::X} named "&c&l닫기" with lore "&a좌클릭&7하여 직업 변경창을 닫습니다."
    set slot 29 of {_inv} to {job.icon::1} named "&6&l명령어" with lore "&7파일이 존재하지 않음"
    set slot 33 of {_inv} to {job.icon::2} named "&6&l직업 설명" with lore "&7강도는 소매치기로 다른 유저의 돈을 뺏는 직업입니다.", "&7전용 도구를 사용해서 유저를 때리면 특정 조건에 따라 돈을 뺏습니다.", " ", "&730초 내에 강도당한 유저가 반격을 하면 돈을 돌려받습니다.", "&7소매치기 도구는 코스트코에서 구매 가능합니다.", "&f&m&l━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━", "&7강도 일급(세전): &f₩ &e0", "&7강도 일급(세후): &f₩ &a0", " "
    set slot 31 of {_inv} to {job.icon::!} named "&c&l주의 사항" with lore "&7이 직업은 &f돈을 벌기 위한 직업이 아닙니다&7.", "&7각종 &c&l&n비난과 멸시&7를 받을 수 있으며, &c&l&n감옥에 수감&7될 수 있습니다."
    open {_inv} to {_p}

