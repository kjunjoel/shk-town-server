    else if uncolored name of event-entity is "기자":
        if player has permission "farmer.user":
            if farmPrice(player) > 0:
                send " &6&l[&6&l&o!&6&l] &f농부는 농지 판매 후 직업을 변경할 수 있습니다." to player
                stop
        if player has permission "cook.user":
            if cookShopCalculate(player) > 0:
                send " &6&l[&6&l&o!&6&l] &f요리사는 요리사 상가 판매 후 직업을 변경할 수 있습니다." to player
                stop
        if {job.change::%uuid of {_p}%} is true:
            send " &6&l[&6&l&o!&6&l] &f직업 변경 쿨타임입니다." to player
            stop
        if group of player contains "학생":
            send " &6&l[&6&l&o!&6&l] &f학생은 직업을 변경하실 수 없습니다." to player
            stop
        if group of player contains "현상수배" or "수감자" or "죄수":
            send " &6&l[&6&l&o!&6&l] &f현상수배이거나 수감자는 직업을 변경하실 수 없습니다." to player
            stop
        if {_something} is set: # 이거 나중에 수정
            send " &6&l[&6&l&o!&6&l] &f직업을 변경하실 수 없습니다." to player
            stop
        NewsNPC(player)
        wait 1 tick
        set {gui.%uuid of player%::NewsNPC} to true

on inventory close:
    if {gui.%uuid of player%::WeddingNPC} is true:
        delete {gui.%uuid of player%::WeddingNPC}
    else if {gui.%uuid of player%::CookNPC} is true:
        delete {gui.%uuid of player%::CookNPC}
    else if {gui.%uuid of player%::RobNPC} is true:
        delete {gui.%uuid of player%::RobNPC}
    else if {gui.%uuid of player%::DefaultNPC} is true:
        delete {gui.%uuid of player%::DefaultNPC}
    else if {gui.%uuid of player%::ArtistNPC} is true:
        delete {gui.%uuid of player%::ArtistNPC}
    else if {gui.%uuid of player%::PhotoNPC} is true:
        delete {gui.%uuid of player%::PhotoNPC}
    else if {gui.%uuid of player%::FarmerNPC} is true:
        delete {gui.%uuid of player%::FarmerNPC}
    else if {gui.%uuid of player%::FisherNPC} is true:
        delete {gui.%uuid of player%::FisherNPC}
    else if {gui.%uuid of player%::MinerNPC} is true:
        delete {gui.%uuid of player%::MinerNPC}
    else if {gui.%uuid of player%::KillingNPC} is true:
        delete {gui.%uuid of player%::KillingNPC}
    else if {gui.%uuid of player%::DoctorNPC} is true:
        delete {gui.%uuid of player%::DoctorNPC}
    else if {gui.%uuid of player%::LawyerNPC} is true:
        delete {gui.%uuid of player%::LawyerNPC}
    else if {gui.%uuid of player%::HomeBNPC} is true:
        delete {gui.%uuid of player%::HomeBNPC}
    else if {gui.%uuid of player%::WriterNPC} is true:
        delete {gui.%uuid of player%::WriterNPC}
    else if {gui.%uuid of player%::DirectorNPC} is true:
        delete {gui.%uuid of player%::DirectorNPC}
    else if {gui.%uuid of player%::NewsNPC} is true:
        delete {gui.%uuid of player%::NewsNPC}

command /jobchangeicon [<text>]:
    permission: op.user
    trigger:
        arg-1 is set
        set {job.icon::%arg-1%} to player's tool
        send "{@prefix} 아이템 %arg-1% 설정 완료"
        stop