options:
    npc: [&6직업&f] 변경
    price: 3000000
    dir: plugins/Skript/data/logs/tax/%now formatted as "yyyy-MM-dd"%.txt
    prefix: &f[ &6&l&o! &f]


function WeddingNPC(p: player):
    set {_inv} to chest inventory with 5 rows named "&2&l주례사 &f직업 변경"
    set slot 11 of {_inv} to {vote.icon::O} named "&2&l주례사&f로 직업 변경" with lore "&a좌클릭&7하여 직업을 변경합니다."
    if {job.change::%uuid of {_p}%} is true:
        set slot 13 of {_inv} to clock named "&a직업 변경 &f쿨타임 여부: &a✔" with lore "&7내일 오전 0시에 변경이 가능합니다."
    else if {job.change::%uuid of {_p}%} is not true:
        set slot 13 of {_inv} to clock named "&a직업 변경 &f쿨타임 여부: &c✖" with lore "&7지금 직업 변경이 가능합니다."
    set slot 15 of {_inv} to {vote.icon::X} named "&c&l닫기" with lore "&a좌클릭&7하여 직업 변경창을 닫습니다."
    set slot 30 of {_inv} to {job.icon::1} named "&6&l명령어" with lore "&7/주례 신청 &f[닉네임]", "&7/주례 종료"
    set slot 32 of {_inv} to {job.icon::2} named "&6&l직업 설명" with lore "&7주례사는 주례를 통해서 돈을 법니다.", "&7주례 비용은 &f결혼 당사자에게 직접 &7받으셔야 합니다.", "&f&m&l━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━", "&7주례사 일급(세전): &f₩ &e400,000", "&7주례사 일급(세후): &f₩ &a360,000", "&f&m&l━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━", "&7평균적인 주례 비용: &f₩ 1,000,000", " "
    open {_inv} to {_p}

function CookNPC(p: player):
    set {_inv} to chest inventory with 5 rows named "&e&l요리사 &f직업 변경"
    set slot 11 of {_inv} to {vote.icon::O} named "&e&l요리사&f로 직업 변경" with lore "&a좌클릭&7하여 직업을 변경합니다."
