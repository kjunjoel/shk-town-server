command /package_reset [<offlineplayer>] [<text>]:
    permission: op.user
    trigger:
        if arg-1 is "all":
            loop all offlineplayers:
                delete {package.%uuid of loop-offlineplayer%::starter}
                delete {package.%uuid of loop-offlineplayer%::basic}
                delete {package.%uuid of loop-offlineplayer%::criminal}
                delete {package.%uuid of loop-offlineplayer%::guild}
                delete {package.%uuid of loop-offlineplayer%::casino}
                delete {package.%uuid of loop-offlineplayer%::startup}
                delete {package.%uuid of loop-offlineplayer%::building}
                wait 1 tick
            send "&a&l[상점]&f 모든 플레이어의 모든 패키지 계정 제한을 초기화했습니다."
            stop
        if arg-2 is "all":
            delete {package.%uuid of arg-1%::starter}
            delete {package.%uuid of arg-1%::basic}
            delete {package.%uuid of arg-1%::criminal}
            delete {package.%uuid of arg-1%::guild}
            delete {package.%uuid of arg-1%::casino}
            delete {package.%uuid of arg-1%::startup}
            delete {package.%uuid of arg-1%::building}
            send "&a&l[상점]&f %arg-1%님의 모든 패키지 계정 제한을 초기화했습니다."
            stop
        delete {package.%uuid of arg-1%::%arg-2%}
        send "&a&l[상점]&f %arg-1%님의 %arg-2% 패키지 계정 제한을 초기화했습니다."

command /package_check [<offlineplayer>]:
    permission: op.user
    trigger:
        send "스타터: %{package.%uuid of arg-1%::starter}%" to player
        send "베이직: %{package.%uuid of arg-1%::basic}%" to player
        send "크리미널: %{package.%uuid of arg-1%::criminal}%" to player
        send "파벌: %{package.%uuid of arg-1%::guild}%" to player
        send "카지노: %{package.%uuid of arg-1%::casino}%" to player
        send "스타트업: %{package.%uuid of arg-1%::startup}%" to player
        send "빌딩: %{package.%uuid of arg-1%::building}%" to player
        stop

command /패키지초기화권 [<text>]:
    permission: op.user
    trigger:
        if arg-1 is "베이직" or "스타터" or "크리미널" or "파벌" or "카지노" or "스타트업" or "빌딩":
            set {_item} to paper named "&f[ &e&l초기화권 &f] &b%arg-1% &f패키지" with lore "&7└ &7거래가 불가능한 아이템입니다.", "&7└ &f우클릭&7하여 사용할 수 있습니다."
            itemGive(player, {_item}, 1, "AdminPackage")
            send "&d&l[패키지]&f &b%arg-1% &f패키지 초기화권을 획득했습니다."
            stop
        else:
            send "&f[ &6&l&o! &f] &f패키지명을 확인 해주세요."
            send "&f[ &6&l&o! &f] &7└ 스타터, 베이직, 크리미널, 파벌, 카지노, 스타트업, 빌딩"


on rightclick:
    if player's tool is paper:
        if uncolored name of player's tool is "SHK WORLD | 스타터 패키지":
            remove 1 of player's tool from player's tool
            balanceAdd(player, 1000000, "Package")
            set {_item} to paper named "&7&lSHK &f&lSmartPhone &a&lv1.0" with custom model data 23
            itemGive(player, {_item}, 1, "Package")
            set {_item} to iron pickaxe
            set unbreaking level of {_item} to 3
            itemGive(player, {_item}, 1, "Package")
            set {_item} to fishing rod
            set unbreaking level of {_item} to 3
            set lure level of {_item} to 3
            itemGive(player, {_item}, 1, "Package")
            set {_item} to iron hoe
            set unbreaking level of {_item} to 3
            itemGive(player, {_item}, 1, "Package")
            set {_item} to paper named "&e&l[직업] &f직업 변경권" with lore "&7중앙광장 지하에서 사용 가능" and "&7거래가 불가능한 아이템입니다."
            itemGive(player, {_item}, 1, "Package")
            set {_item} to paper named "<##2288FF>&l상어 &f&l모자" with lore "&7우클릭하여 치장 착용" and "&7거래가 불가능한 아이템입니다." with custom model data 65
            itemGive(player, {_item}, 1, "Package")
            send "[ &6&l! &f] 스타터 패키지 아이템을 획득하였습니다."

        else if uncolored name of player's tool is "SHK WORLD | 베이직 패키지":
            remove 1 of player's tool from player's tool
            balanceAdd(player, 2000000, "Package")
            set {_item} to paper named "&6택시 &f호출권" with lore "&7스마트폰에서 택시를 호출할 수 있습니다." and "&7거래가 불가능한 아이템입니다."
