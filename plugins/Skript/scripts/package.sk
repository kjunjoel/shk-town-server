 # 변수
# {package.%uuid of player%::%name%} | 플레이어가 name 패키지를 산 횟수

on rightclick on entity:
    if name of event-entity is "패키지 구매":
        execute player command "패키지"

on rightclick:
    if uncolored name of player's tool is "[ 초기화권 ] 스타터 패키지":
        delete {package.%uuid of player%::starter}
        send "&d&l[패키지]&f &e%player%님&f의 스타터 패키지 제한을 초기화했습니다."
        remove 1 of player's tool from player's tool
    else if uncolored name of player's tool is "[ 초기화권 ] 베이직 패키지":
        delete {package.%uuid of player%::basic}
        send "&d&l[패키지]&f &e%player%님&f의 베이직 패키지 제한을 초기화했습니다."
        remove 1 of player's tool from player's tool
    else if uncolored name of player's tool is "[ 초기화권 ] 크리미널 패키지":
        delete {package.%uuid of player%::criminal}
        send "&d&l[패키지]&f &e%player%님&f의 크리미널 패키지 제한을 초기화했습니다."
        remove 1 of player's tool from player's tool
    else if uncolored name of player's tool is "[ 초기화권 ] 파벌 패키지":
        delete {package.%uuid of player%::guild}
        send "&d&l[패키지]&f &e%player%님&f의 파벌 패키지 제한을 초기화했습니다."
        remove 1 of player's tool from player's tool
    else if uncolored name of player's tool is "[ 초기화권 ] 카지노 패키지":
        delete {package.%uuid of player%::casino}
        send "&d&l[패키지]&f &e%player%님&f의 카지노 패키지 제한을 초기화했습니다."
        remove 1 of player's tool from player's tool
    else if uncolored name of player's tool is "[ 초기화권 ] 스타트업 패키지":
        delete {package.%uuid of player%::startup}
        send "&d&l[패키지]&f &e%player%님&f의 스타트업 패키지 제한을 초기화했습니다."
        remove 1 of player's tool from player's tool
    else if uncolored name of player's tool is "[ 초기화권 ] 빌딩 패키지":
        delete {package.%uuid of player%::building}
        send "&d&l[패키지]&f &e%player%님&f의 빌딩 패키지 제한을 초기화했습니다."
        remove 1 of player's tool from player's tool

command /패키지:
    trigger:
        set {_inv} to chest inventory with 6 rows named "&a&l[상점] &f패키지상점"
        set {_item} to paper named "&bSHK WORLD &f| &e&l스타터 &f패키지" with custom model data 11 with lore "&7└ 1,000,000원", "&7└ SHK SmartPhone v1.0", "&7└ 철 곡괭이 (내구성 3)", "&7└ 낚싯대 (내구성 3, 미끼 3)", "&7└ 철 괭이 (내구성 3)", "&7└ 직업 변경권", "&7└ 상어 모자", "&f", "&6구매 &f가격: &e&l9,980&e캐시", "&d계정 &f제한 개수: &b%1 - {package.%uuid of player%::starter}%/1개 &f남음", "&f", "&6좌클릭&f하여 1개 &6구매"
        set slot 11 of {_inv} to {_item}
        set {_item} to paper named "&bSHK WORLD &f| &6&l베이직 &f패키지" with custom model data 11 with lore "&7└ 2,000,000원", "&7└ 택시 호출권 20개", "&7└ 스테이크 64개", "&7└ 직업 변경권 3개", "&7└ 상어 모자", "&f", "&6구매 &f가격: &e&l19,980&e캐시", "&d계정 &f제한 개수: &b%3 - {package.%uuid of player%::basic}%/3개 &f남음", "&f", "&6좌클릭&f하여 1개 &6구매"
        set slot 12 of {_inv} to {_item}
        set {_item} to paper named "&bSHK WORLD &f| &4&l크리미널 &f패키지" with custom model data 11 with lore "&7└ 3,000,000원", "&7└ 택시 호출권 20개", "&7└ M1A1 Thompson", "&7└ .45 ACP(30발) 10개 상자 10개", "&7└ 직업 변경권", "&7└ 안경 치장 중 택 1", "&f", "&6구매 &f가격: &e&l49,980&e캐시", "&d계정 &f제한 개수: &b%3 - {package.%uuid of player%::criminal}%/3개 &f남음", "&f", "&6좌클릭&f하여 1개 &6구매"
        set slot 13 of {_inv} to {_item}
        set {_item} to paper named "&bSHK WORLD &f| &a&l파벌 &f패키지" with custom model data 11 with lore "&7└ 500,000원", "&7└ 택시 호출권 20개", "&7└ 파벌 생성권", "&7└ 직업 변경권", "&7└ 안경 치장 중 택 1", "&f", "&6구매 &f가격: &e&l49,980&e캐시", "&d계정 &f제한 개수: &b%3 - {package.%uuid of player%::guild}%/3개 &f남음", "&f", "&6좌클릭&f하여 1개 &6구매"
        set slot 14 of {_inv} to {_item}
        set {_item} to paper named "&bSHK WORLD &f| &d&l카지노 &f패키지" with custom model data 11 with lore "&7└ 3,000,000원", "&7└ 택시 호출권 10개", "&7└ [CASINO] $100 Chip 150개", "&7└ 직업 변경권", "&f", "&6구매 &f가격: &e&l39,980&e캐시", "&d계정 &f제한 개수: &b%5 - {package.%uuid of player%::casino}%/5개 &f남음", "&f", "&6좌클릭&f하여 1개 &6구매"
        set slot 15 of {_inv} to {_item}
        set {_item} to paper named "&bSHK WORLD &f| &e&l스타트업 &f패키지" with custom model data 11 with lore "&7└ 상가 구매 지원 쿠폰 (100,000,000원)", "&7└ 직업 변경권", "&f", "&6구매 &f가격: &e&l59,980&e캐시", "&d계정 &f제한 개수: &b%2 - {package.%uuid of player%::startup}%/2개 &f남음", "&f", "&6좌클릭&f하여 1개 &6구매"
        set slot 20 of {_inv} to {_item}
        set {_item} to paper named "&bSHK WORLD &f| &e&l빌딩 &f패키지" with custom model data 11 with lore "&7└ 빌딩 구매 지원 쿠폰 (400,000,000원)", "&7└ 직업 변경권", "&f", "&6구매 &f가격: &e&l149,980&e캐시", "&d계정 &f제한 개수: &b%3 - {package.%uuid of player%::building}%/3개 &f남음", "&f", "&6좌클릭&f하여 1개 &6구매"
        set slot 21 of {_inv} to {_item}
        open {_inv} to player
        set {_item} to paper named "&bSHK WORLD &f| &c&l결혼 &f패키지" with custom model data 11 with lore "&7└ 축의금 5,000,000원", "&7└ 결혼 반지 1개", "&7└ 사랑의 큐피트 5개", "&f", "&6구매 &f가격: &e&l20,000&e캐시", "&f", "&6좌클릭&f하여 1개 &6구매"
        set slot 22 of {_inv} to {_item}
        open {_inv} to player
        set {_item} to paper named "&bSHK WORLD &f| 쀂 &6&l택시 &f패키지" with custom model data 11 with lore "&7└ 택시 호출권 50개", "&f", "&6구매 &f가격: &e&l4,980&e캐시", "&f", "&6좌클릭&f하여 1개 &6구매"
        set slot 23 of {_inv} to {_item}
        open {_inv} to player

        set {_item} to paper named "&f[ &e&l초기화권 &f] &e&l스타터 &f&l패키지" with custom model data 11 with lore "&7└ &7거래가 불가능한 아이템입니다.", "&7└ &f우클릭&7하여 사용할 수 있습니다.", "&f", "&6구매 &f가격: &e&l980&e캐시", "&f", "&6좌클릭&f하여 1개 &6구매"
        set slot 29 of {_inv} to {_item}
        set {_item} to paper named "&f[ &e&l초기화권 &f] &6&l베이직 &f&l패키지" with custom model data 11 with lore "&7└ &7거래가 불가능한 아이템입니다.", "&7└ &f우클릭&7하여 사용할 수 있습니다.", "&f", "&6구매 &f가격: &e&l5,980&e캐시", "&f", "&6좌클릭&f하여 1개 &6구매"
        set slot 30 of {_inv} to {_item}
        set {_item} to paper named "&f[ &e&l초기화권 &f] &4&l크리미널 &f&l패키지" with custom model data 11 with lore "&7└ &7거래가 불가능한 아이템입니다.", "&7└ &f우클릭&7하여 사용할 수 있습니다.", "&f", "&6구매 &f가격: &e&l14,980&e캐시", "&f", "&6좌클릭&f하여 1개 &6구매"
        set slot 31 of {_inv} to {_item}
        set {_item} to paper named "&f[ &e&l초기화권 &f] &a&l파벌 &f&l패키지" with custom model data 11 with lore "&7└ &7거래가 불가능한 아이템입니다.", "&7└ &f우클릭&7하여 사용할 수 있습니다.", "&f", "&6구매 &f가격: &e&l14,980&e캐시", "&f", "&6좌클릭&f하여 1개 &6구매"
        set slot 32 of {_inv} to {_item}
        set {_item} to paper named "&f[ &e&l초기화권 &f] &d&l카지노 &f&l패키지" with custom model data 11 with lore "&7└ &7거래가 불가능한 아이템입니다.", "&7└ &f우클릭&7하여 사용할 수 있습니다.", "&f", "&6구매 &f가격: &e&l11,980&e캐시", "&f", "&6좌클릭&f하여 1개 &6구매"
        set slot 33 of {_inv} to {_item}
        set {_item} to paper named "&f[ &e&l초기화권 &f] &e&l스타트업 &f&l패키지" with custom model data 11 with lore "&7└ &7거래가 불가능한 아이템입니다.", "&7└ &f우클릭&7하여 사용할 수 있습니다.", "&f", "&6구매 &f가격: &e&l11,980&e캐시", "&f", "&6좌클릭&f하여 1개 &6구매"
        set slot 38 of {_inv} to {_item}
        set {_item} to paper named "&f[ &e&l초기화권 &f] &e&l빌딩 &f&l패키지" with custom model data 11 with lore "&7└ &7거래가 불가능한 아이템입니다.", "&7└ &f우클릭&7하여 사용할 수 있습니다.", "&f", "&6구매 &f가격: &e&l44,980&e캐시", "&f", "&6좌클릭&f하여 1개 &6구매"
        set slot 39 of {_inv} to {_item}
        open {_inv} to player

on inventory click:
    if uncolored display name of event-inventory is "[상점] 패키지상점":
        cancel event
        click type is left mouse button
        if clicked slot is 11:
            if {package.%uuid of player%::starter} >= 1:
                send "&a&l[상점]&f 계정 제한을 초과하여 구매하실 수 없습니다."
                stop
            if {cash::%uuid of player%} < 9980:
                send "&a&l[상점]&f 잔액이 부족합니다."
                stop
            add 1 to {package.%uuid of player%::starter}
            cashRemove(player, 9980, "Pakcage")
            set {_item} to paper named "&bSHK WORLD &f| &e&l스타터 &f패키지" with custom model data 11 with lore "&7└ 1,000,000원", "&7└ SHK SmartPhone v1.0", "&7└ 철 곡괭이 (내구성 3)", "&7└ 낚싯대 (내구성 3, 미끼 3)", "&7└ 철 괭이 (내구성 3)", "&7└ 직업 변경권", "&7└ 상어 모자"
            itemGive(player, {_item}, 1, "Package")
            send "&a&l[상점]&f 성공적으로 상품을 구매했습니다. &c(-9,980캐시)"
            execute player command "패키지"

        else if clicked slot is 12:
            if {package.%uuid of player%::basic} >= 3:
                send "&a&l[상점]&f 계정 제한을 초과하여 구매하실 수 없습니다."
                stop
            if {cash::%uuid of player%} < 19980:
                send "&a&l[상점]&f 잔액이 부족합니다."
                stop
            add 1 to {package.%uuid of player%::basic}
