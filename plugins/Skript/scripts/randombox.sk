options:
    prefix: [ &6&l! &f]

on rightclick with gold ingot:
    if uncolored name of event-item is "[ 계묘년 ] 코인" or "[ 계묘년 ] 코인 ⚝":
        set {randombox.blackrabbit::%uuid of player%} to 0 if {randombox.blackrabbit::%uuid of player%} isn't set
        set {_i} to {randombox.blackrabbit::%uuid of player%}
        remove 1 of player's tool from player's tool
        set {_n} to random integer between 1 and 200
        if {_n} is between 1 and 20:
            set {_number} to round up ({_n}/5)
            set {_br} to round down ({_i}/(2^({_number}-1)))
            if mod({_br}, 2) is 0:
                add 2^({_number}-1) to {randombox.blackrabbit::%uuid of player%}
            else:
                send "{@prefix} 안타깝게도 중복된 아이템이 나와서 &c&l꽝&f입니다!" to player
                stop
            if {_number} is 1:
                send "{@prefix} &8&l검은 롭이어 토끼 모자 &7교환권&f을 획득하였습니다!" to player
                set {_item} to paper named "&8&l검은 롭이어 토끼 모자 &f교환권" with custom model data 30 with lore "&7거래가 불가능한 아이템입니다."
            else if {_number} is 2:
                send "{@prefix} &8&l검은 토끼 인형 &7교환권&f을 획득하였습니다!" to player
                set {_item} to paper named "&8&l검은 토끼 인형 &7교환권" with custom model data 97 with lore "&7거래가 불가능한 아이템입니다."
            else if {_number} is 3:
                send "{@prefix} &8&l검은 토끼 모자 &7교환권&f을 획득하였습니다!" to player
                set {_item} to paper named "&8&l검은 토끼 모자 &7교환권" with custom model data 98 with lore "&7거래가 불가능한 아이템입니다."
            else if {_number} is 4:
                send "{@prefix} &8&l검은 토끼 머리띠 &7교환권&f을 획득하였습니다!" to player
                set {_item} to paper named "&8&l검은 토끼 머리띠 &7교환권" with custom model data 99 with lore "&7거래가 불가능한 아이템입니다."
            else:
                send "{@prefix} 안타깝게도 중복된 아이템이 나와서 &c&l꽝&f입니다!" to player
                stop
        else if {_n} is between 21 and 28:
            send "{@prefix} &6택시 &f호출권을 획득하였습니다!" to player
            set {_item} to paper named "&6택시 &f호출권" with lore "&7스마트폰에서 택시를 호출할 수 있습니다." and "&7거래가 불가능한 아이템입니다."
        else if {_n} is between 29 and 43:
            send "{@prefix} 50,000원 1개를 획득하였습니다!" to player
            set {_item} to gold ingot with custom model data 4 named "&f50,000원" with lore "&f[<##F77E21>상어은행&f]"
        else if {_n} is between 44 and 53:
            send "{@prefix} 50,000원 2개를 획득하였습니다!" to player
            set {_item} to 2 of gold ingot with custom model data 4 named "&f50,000원" with lore "&f[<##F77E21>상어은행&f]"
        else if {_n} is between 54 and 60:
            send "{@prefix} 50,000원 3개를 획득하였습니다!" to player
            set {_item} to 3 of gold ingot with custom model data 4 named "&f50,000원" with lore "&f[<##F77E21>상어은행&f]"
        else if {_n} is between 61 and 64:
            send "{@prefix} 50,000원 6개를 획득하였습니다!" to player
            set {_item} to 6 of gold ingot with custom model data 4 named "&f50,000원" with lore "&f[<##F77E21>상어은행&f]"
        else if {_n} is between 65 and 74:
            send "{@prefix} &f&l확성기를 획득하였습니다!" to player
            set {_item} to paper with custom model data 9 named "&f&l확성기"
        else if {_n} is between 75 and 84:
            send "{@prefix} &f[ &6&l뚝배기 &e&l밧줄 &f]을 획득하였습니다!" to player
            set {_item} to lead named "&f[ &6&l뚝배기 &e&l밧줄 &f]"
        else if {_n} is between 85 and 98:
            send "{@prefix} 스테이크 10개를 획득하였습니다." to player
            set {_item} to 10 of cooked beef
        else if {_n} is between 99 and 100:
            send "{@prefix} &e&l[직업] &f직업 변경권을 획득하였습니다." to player
            set {_item} to paper named "&e&l[직업] &f직업 변경권" with lore "&7중앙광장 지하에서 사용 가능" and "&7거래가 불가능한 아이템입니다."
        else:
            send "{@prefix} 안타깝게도 &c&l꽝&f입니다!" to player
        itemGive(player, {_item}, item amount of {_item}, "Randombox")

on rightclick with paper:
    if uncolored name of event-item is "Goodbye2022 랜덤 치장 뽑기권" or "[ GoodBye 2022 ] 랜덤 치장 뽑기권 ⚝":
        remove 1 of player's tool from player's tool
        set {_n} to random integer between 1 and 32
        if {_n} is 1:
            send "{@prefix} [2022 새해 이벤트] &f&l호랑이 &f머리탈을 획득하였습니다!" to player
            set {_item} to paper named "&f&l호랑이 &f머리탈" with custom model data 13 with lore "&7우클릭하여 치장 착용" and "&7거래가 불가능한 아이템입니다."
        else if {_n} is 2:
            send "{@prefix} [2022 새해 이벤트] &f&l호랑이 &f장갑을 획득하였습니다!" to player
            set {_item} to paper named "&f&l호랑이 &f장갑" with custom model data 14 with lore "&7거래가 불가능한 아이템입니다."
        else if {_n} is 3:
            send "{@prefix} [2022 새해 이벤트] 호랑이 &f&l호랑이 &f꼬리털을 획득하였습니다!" to player
            set {_item} to paper named "&f&l호랑이 &f꼬리털" with custom model data 15 with lore "&7우클릭하여 치장 착용" and "&7거래가 불가능한 아이템입니다."
        else if {_n} is 4:
            send "{@prefix} [2022 광복절 이벤트] &c&l태&9&l극&f&l기 &7&l깃발&f을 획득하였습니다!" to player
            set {_item} to paper named "&c&l태&9&l극&f&l기 &7&l깃발" with custom model data 25 with lore "&7거래가 불가능한 아이템입니다." 
        else if {_n} is 5:
            send "{@prefix} [2022 광복절 이벤트] &c&l태&9&l극&f&l기 &7&l망토&f를 획득하였습니다!" to player
            set {_item} to paper named "&c&l태&9&l극&f&l기 &7&l망토" with custom model data 26 with lore "&7우클릭하여 치장 착용" and "&7거래가 불가능한 아이템입니다."
        else if {_n} is 6:
            send "{@prefix} [2022 광복절 이벤트] &f&l고양이 헤드폰<##FFC0CB>&l(핑크)&f을 획득하였습니다!" to player
            set {_item} to paper named "&f&l고양이 헤드폰<##FFC0CB>&l(핑크)" with custom model data 27 with lore "&7우클릭하여 치장 착용" and "&7거래가 불가능한 아이템입니다." 
        else if {_n} is 7:
            send "{@prefix} [2022 광복절 이벤트] &f&l헤드폰&8&l(블랙)&f을 획득하였습니다!" to player
            set {_item} to paper named "&f&l헤드폰&8&l(블랙)" with custom model data 28 with lore "&7우클릭하여 치장 착용" and "&7거래가 불가능한 아이템입니다."
        else if {_n} is 8:
            send "{@prefix} [2022 광복절 이벤트] <##964B00>&l곰돌이 헬멧&f을 획득하였습니다!" to player
            set {_item} to paper named "<##964B00>&l곰돌이 헬멧" with custom model data 29 with lore "&7우클릭하여 치장 착용" and "&7거래가 불가능한 아이템입니다."
        else if {_n} is 9:
            send "{@prefix} [2022 광복절 이벤트] &8&l검은 롭이어 토끼 모자&f를 획득하였습니다!" to player
            set {_item} to paper named "&8&l검은 롭이어 토끼 모자" with custom model data 30 with lore "&7우클릭하여 치장 착용" and "&7거래가 불가능한 아이템입니다."
        else if {_n} is 10:
            send "{@prefix} [2022 광복절 이벤트] &f&l고양이 헤드폰&9&l(블루)&f을 획득하였습니다!" to player
            set {_item} to paper named "&f&l고양이 헤드폰&9&l(블루)" with custom model data 31 with lore "&7우클릭하여 치장 착용" and "&7거래가 불가능한 아이템입니다."
        else if {_n} is 11:
            send "{@prefix} [2022 추석 이벤트] &e&l보름달&f을 획득하였습니다!" to player
            set {_item} to paper named "&e&l보름달" with custom model data 4 with lore "&7우클릭하여 치장 착용" and "&7거래가 불가능한 아이템입니다."
        else if {_n} is 12:
            send "{@prefix} [2022 추석 이벤트] &a&l송&c&l편&f을 획득하였습니다!" to player
            set {_item} to paper named "&a&l송&c&l편" with custom model data 5 with lore "&7우클릭하여 치장 착용" and "&7거래가 불가능한 아이템입니다."
        else if {_n} is 13:
            send "{@prefix} [2022 한글날 이벤트] <##1F5458>&l내시 &7&l모자&f을 획득하였습니다!" to player
            set {_item} to paper named "<##1F5458>&l내시 &7&l모자" with custom model data 56 with lore "&7우클릭하여 치장 착용" and "&7거래가 불가능한 아이템입니다."
        else if {_n} is 14:
            send "{@prefix} [2022 한글날 이벤트] <##272727>&l대감 &7&l모자&f을 획득하였습니다!" to player
            set {_item} to paper named "<##272727>&l대감 &7&l모자" with custom model data 57 with lore "&7우클릭하여 치장 착용" and "&7거래가 불가능한 아이템입니다."
        else if {_n} is 15:
