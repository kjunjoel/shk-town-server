on rightclick with gold ingot:
    if uncolored name of event-item is "[ 설날 ] 코인" or "[ 설날 ] 코인 ⚝":
        set {randombox.seollal::%uuid of player%} to 0 if {randombox.seollal::%uuid of player%} isn't set
        set {_i} to {randombox.seollal::%uuid of player%}
        remove 1 of player's tool from player's tool
        set {_n} to random integer between 1 and 200
        if {_n} is between 1 and 20:
            set {_number} to round up ({_n}/5)
            set {_br} to round down ({_i}/(2^({_number}-1)))
            if mod({_br}, 2) is 0:
                add 2^({_number}-1) to {randombox.seollal::%uuid of player%}
            else:
                send "{@prefix} 안타깝게도 중복된 아이템이 나와서 &c&l꽝&f입니다!" to player
