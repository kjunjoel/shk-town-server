            set {_item} to paper named "&e&l[직업] &f직업 변경권" with lore "&7중앙광장 지하에서 사용 가능" and "&7거래가 불가능한 아이템입니다."
        else:
            send "{@prefix} 안타깝게도 &c&l꽝&f입니다!" to player
        itemGive(player, {_item}, item amount of {_item}, "Randombox")

on rightclick with stick:
    if uncolored name of event-item is "[ 봄이온 3·1절 ] 코인":
        set {randombox.Independence_Movement_Day::%uuid of player%} to 0 if {randombox.Independence_Movement_Day::%uuid of player%} isn't set
        set {_i} to {randombox.Independence_Movement_Day::%uuid of player%}
        if item amount of player's tool < 2:
            send "{@prefix} 코인 2개를 손에 들고 우클릭해주세요."
            stop
        remove 2 of player's tool from player's tool
        set {_n} to random integer between 1 and 200
        set {_br} to round down ({_i}/(2^({_n}-1)))
        if {_n} is between 1 and 16:
            if mod({_br}, 2) is 0:
                add 2^({_n}-1) to {randombox.Independence_Movement_Day::%uuid of player%}
            else:
                send "{@prefix} 안타깝게도 중복된 아이템이 나와서 &c&l꽝&f입니다!" to player
                stop
            if {_n} is between 1 and 4:
                execute console command "lp user %player% permission set cosmeticscore.user.cosmetics.wear.flowercrown"
                send "{@prefix} &a&l화관&f을 뽑았습니다!" to player
                send "{@prefix} 치장 착용 권한을 획득하였습니다. 옷장에서 착용할 수 있습니다."
                send "&7     └ 옷장은 중앙광장이나 코스트코에서 이용할 수 있습니다."

            else if {_n} is 5:
                execute console command "lp user %player% permission set cosmeticscore.user.cosmetics.wear.oriental_windows"
                send "{@prefix} &d&l동양 &f&l창문&f을 뽑았습니다!" to player
                send "{@prefix} 치장 착용 권한을 획득하였습니다. 옷장에서 착용할 수 있습니다."
                send "&7     └ 옷장은 중앙광장이나 코스트코에서 이용할 수 있습니다."

            else if {_n} is between 6 and 8:
                execute console command "lp user %player% permission set cosmeticscore.user.cosmetics.wear.roseofsharon"
                send "{@prefix} &d&l무궁화 &f&l머리핀&f을 뽑았습니다!" to player
                send "{@prefix} 치장 착용 권한을 획득하였습니다. 옷장에서 착용할 수 있습니다."
                send "&7     └ 옷장은 중앙광장이나 코스트코에서 이용할 수 있습니다."

            else if {_n} is 9:
                send "{@prefix} &f&l양산&f을 획득하였습니다!" to player
                set {_item} to paper named "&f&l양산" with custom model data 111 with lore "&7손에 들어서 치장 착용 가능합니다." and "&7거래가 불가능한 아이템입니다."

            else if {_n} is between 10 and 11:
                send "{@prefix} &f[ 지사 ] 칭호 교환권을 획득하였습니다!" to player
                set {_item} to paper named "&f[ 지사 ] 칭호 교환권" with lore "&7거래가 불가능한 아이템입니다."
            else if {_n} is 12:
                send "{@prefix} &f[ 열사 ] 교환권을 획득하였습니다!" to player
                set {_item} to paper named "&f[ 열사  ] 칭호 교환권" with lore "&7거래가 불가능한 아이템입니다."
            else if {_n} is 13:
