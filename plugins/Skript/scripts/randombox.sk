command /randombox_reset <offlineplayer>:
    permission: op.user
    trigger:
        delete {randombox.christmas::%uuid of arg-1%}
        delete {randombox.blackrabbit::%uuid of arg-1%}
        delete {randombox.blacktiger::%uuid of arg-1%}
        delete {randombox.seollal::%uuid of arg-1%}
        delete {randombox.Independence_Movement_Day::%uuid of arg-1%}
        delete {randombox.halloween::%uuid of arg-1%}
        delete {randombox.ppaeppaero::%uuid of arg-1%}
        send "deleted record of %arg-1%'s randombox(christmas)."
        send "deleted record of %arg-1%'s randombox(black rabbit)."
        send "deleted record of %arg-1%'s randombox(black tiger)."
        send "deleted record of %arg-1%'s randombox(seollal)."
        send "deleted record of %arg-1%'s randombox(Independence_Movement_Day)."
        send "deleted record of %arg-1%'s randombox(halloween)."
        send "deleted record of %arg-1%'s randombox(ppaeppaero)."



command /randombox_get <offlineplayer>:
    permission: op.user
    trigger:
        set {_i} to {randombox.christmas::%uuid of arg-1%}
        loop 15 times:
            set {_n} to loop-number
            set {_br} to round down ({_i}/(2^(loop-number -1)))
            if mod({_br}, 2) isn't 0:
                send "{@prefix} 이 아이템은 못 얻었습니다!" to player
            if {_n} is 1:
                send "{@prefix} <##006600>&l산타 <##663300>&l머리띠&f를 획득한 기록이 있습니다" to player
            else if {_n} is 2:
                send "{@prefix} <##FF0000>&l호랑가시 <##666666>&l뱃지&f를 획득한 기록이 있습니다" to player
            else if {_n} is 3:
                send "{@prefix} <##66360C>&l루돌프 <##E7DE79>&l머리띠&f를 획득한 기록이 있습니다" to player
            else if {_n} is 4:
                send "{@prefix} <##FF0000>&l크리스마스 &f&l막대사탕&f를 획득한 기록이 있습니다" to player
            else if {_n} is 5:
                send "{@prefix} &8&l검은색 &f&l목도리&f를 획득한 기록이 있습니다" to player
            else if {_n} is 6:
                send "{@prefix} <##B19DC9>&l보라색 &f&l목도리&f를 획득한 기록이 있습니다" to player
            else if {_n} is 7:
                send "{@prefix} <##FF0000>&l빨간색 &f&l목도리&f를 획득한 기록이 있습니다" to player
            else if {_n} is 8:
                send "{@prefix} &f&l산타 <##FF0000>&l모자&f를 획득한 기록이 있습니다" to player
            else if {_n} is 9:
                send "{@prefix} &f&l눈구름&f를 획득한 기록이 있습니다" to player
            else if {_n} is 10:
                send "{@prefix} &f&l눈사람&f를 획득한 기록이 있습니다" to player
            else if {_n} is 11:
                send "{@prefix} &f루돌프 칭호를 획득한 기록이 있습니다" to player
            else if {_n} is 12:
                send "{@prefix} &f瑞雪 칭호를 획득한 기록이 있습니다" to player
            else if {_n} is 13:
                send "{@prefix} &f눈송이 칭호를 획득한 기록이 있습니다" to player
            else if {_n} is 14:
                send "{@prefix} &f산타클로스 칭호를 획득한 기록이 있습니다" to player
            else if {_n} is 15:
                send "{@prefix} &f한적한 겨울 칭호를 획득한 기록이 있습니다" to player


command /코인받기 [<int>]:
    permission: op
    permission message: &c권한이 없습니다.
    trigger:
        if arg-1 isn't set:
            send "&f"
            send "{@prefix} /코인받기 [int]"
            send "&cint는 커스텀 모델 아이디입니다."
            send "&f"
            stop
        send "{@prefix} %arg-1%번 아이템 지급 완료" to player
        set {_item} to gold ingot with custom model data arg-1 named "&f%arg-1%번" with lore "&7보기용"
        itemGive(player, {_item}, item amount of {_item}, "Randombox")


on rightclick:
    if uncolored name of player's tool is "[ 여름여행 코인 ]":
        if item amount of player's tool < 3:
            send "{@prefix} &f[&b&l여름&a&l여행&f] &f코인 &f3개를 손에 들고 우클릭해주세요."
            stop
        set {randombox.halloween::%uuid of player%} to 0 if {randombox.halloween::%uuid of player%} isn't set
        set {_i} to {randombox.halloween::%uuid of player%}
        remove 3 of player's tool from player's tool
        set {_n} to random integer between 1 and 250
        if {_n} is between 1 and 100:
            set {_number} to round up ({_n}/5) # 1에서 20 랜덤으로 뽑음
            set {_br} to round down ({_i}/(2^({_number}-1))) # {_br} = {_i} << ({_number} - 1)
            if mod({_br}, 2) is 0:
                add 2^({_number}-1) to {randombox.halloween::%uuid of player%}
            else:
                send "{@prefix} 안타깝게도 중복된 아이템이 나와서 &c&l꽝&f입니다!" to player
                stop
            if {_number} is 1:
                execute console command "lp user %player% permission set cosmeticscore.user.cosmetics.wear.camera"
                send "{@prefix} &8&l사진기 &f를 뽑았습니다!" to player
                send "{@prefix} 치장 착용 권한을 획득하였습니다. 옷장에서 착용할 수 있습니다."
                send "&7     └ 옷장은 중앙광장이나 코스트코에서 이용할 수 있습니다."
            else if {_number} is 2:
                set {_item} to paper with custom model data 154 named "&b&l손선풍기" with lore "&7손에 들어 착용이 가능한 치장입니다." and "&7거래가 불가능한 아이템입니다."
                send "{@prefix} &b&l손선풍기 &f를 뽑았습니다!" to player
                send "{@prefix} 손에 드는 아이템입니다! &c옷장에서 착용이 &n불가능&f합니다."
            else if {_number} is 3:
                execute console command "lp user %player% permission set cosmeticscore.user.cosmetics.wear.ocean"
                send "{@prefix} &e&l여름 &b&l바다 &f를 뽑았습니다!" to player
                send "{@prefix} 치장 착용 권한을 획득하였습니다. 옷장에서 착용할 수 있습니다."
                send "&7     └ 옷장은 중앙광장이나 코스트코에서 이용할 수 있습니다."
            else if {_number} is 4:
                execute console command "lp user %player% permission set cosmeticscore.user.cosmetics.wear.straw_hat"
                send "{@prefix} &6&l밀짚모자 &f를 뽑았습니다!" to player
                send "{@prefix} 치장 착용 권한을 획득하였습니다. 옷장에서 착용할 수 있습니다."
                send "&7     └ 옷장은 중앙광장이나 코스트코에서 이용할 수 있습니다."
            else if {_number} is 5:
                send "{@prefix} &f[ <##72e9ff>&l立<##3cd1ec>&l夏 &f] &e칭호&f를 획득하였습니다!" to player
                set {_item} to {prefix.entersummer}
            else if {_number} is 6:
                send "{@prefix} &f[ <##e77379>&l수<##979c45>&l박<##e77379>&l바 &f] &e칭호&f를 획득하였습니다!" to player
                set {_item} to {prefix.watermelonbar}
            else if {_number} is 7:
                send "{@prefix} &f[ <##398872>&l트<##fcf076>&l로<##ff7796>&l피<##b9efd8>&l컬 &f] &e칭호&f를 획득하였습니다!" to player
                set {_item} to {prefix.tropical}
            else if {_number} is 8:
                send "{@prefix} &f[ <##01add5>&l시원한 바다 &f] &e칭호&f를 획득하였습니다!" to player
                set {_item} to {prefix.coolsea}
            else:
                send "{@prefix} 안타깝게도 &c&l꽝&f입니다!" to player
                stop
        else if {_n} is between 101 and 120:
            send "{@prefix} &f&l확성기 &f3개를 획득하였습니다!" to player
            set {_item} to 3 of paper with custom model data 9 named "&f&l확성기"
        else if {_n} is between 121 and 150:
            send "{@prefix} &a&l10,000원&f을 획득하였습니다!" to player
            set {_item} to gold ingot with custom model data 3 named "&f10,000원" with lore "&f[<##F77E21>상어은행&f]"
        else if {_n} is between 151 and 180:
            send "{@prefix} &2&l30,000원&f을 획득하였습니다!" to player
            set {_item} to 3 of gold ingot with custom model data 3 named "&f10,000원" with lore "&f[<##F77E21>상어은행&f]"
        else if {_n} is between 181 and 200:
            send "{@prefix} &5&l50,000원&f을 획득하였습니다!" to player
            set {_item} to gold ingot with custom model data 4 named "&f50,000원" with lore "&f[<##F77E21>상어은행&f]"
        else if {_n} is between 201 and 210:
            send "{@prefix} &6&l100,000원&f을 획득하였습니다!" to player
            set {_item} to 2 of gold ingot with custom model data 4 named "&f50,000원" with lore "&f[<##F77E21>상어은행&f]"
        else if {_n} is between 211 and 230:
            send "{@prefix} &f[ &b&l여름&a&l여행 &f] 코인 &e3개&f를 획득하였습니다!" to player
            set {_item} to 3 of {travel.coin}
        else if {_n} is between 231 and 240:
            send "{@prefix} &f[ &b&l여름&a&l여행 &f] 코인 &e15개&f를 획득하였습니다!" to player
            set {_item} to 15 of {travel.coin}
        else if {_n} is between 241 and 245:
            send "{@prefix} &f[ &b&l여름&a&l여행 &f] 코인 &e30개&f를 획득하였습니다!" to player
            set {_item} to 30 of {travel.coin}
        else:
            send "{@prefix} 안타깝게도 &c&l꽝&f입니다!" to player
        itemGive(player, {_item}, item amount of {_item}, "HalloweenBox")

