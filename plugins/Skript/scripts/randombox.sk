            set {_item} to paper named "<##0072a1>&l유생 &7&l모자" with custom model data 58 with lore "&7우클릭하여 치장 착용" and "&7거래가 불가능한 아이템입니다."
        else if {_n} is 16:
            send "{@prefix} [2022 한글날 이벤트] &e&l왕 &7&l모자&f를 획득하였습니다!" to player
            set {_item} to paper named "&e&l왕 &7&l모자" with custom model data 59 with lore "&7우클릭하여 치장 착용" and "&7거래가 불가능한 아이템입니다."
        else if {_n} is 17:
            send "{@prefix} [2022 할로윈 이벤트]  &8&l박쥐 모자&f를 획득하였습니다!" to player
            set {_item} to paper named " &8&l박쥐 모자" with custom model data 66 with lore "&7박쥐 날개가 달려있는 귀여운 모자다", "&7우클릭하여 치장 착용" and "&7거래가 불가능한 아이템입니다."
        else if {_n} is 18:
            send "{@prefix} [2022 할로윈 이벤트] &6&l[&e&l사탕 바구니&6&l]&f를 획득하였습니다!" to player
            set {_item} to paper named "&6&l[&e&l사탕 바구니&6&l]" with custom model data 78 with lore "&7사탕이 가득한 호박모양 바구니다" and "&7거래가 불가능한 아이템입니다."
        else if {_n} is 19:
            send "{@prefix} [2022 할로윈 이벤트] &5&l[&d&l할로윈 마녀의 모자&5&l]&f를 획득하였습니다!" to player
            set {_item} to paper named "&5&l[&d&l할로윈 마녀의 모자&5&l]" with custom model data 77 with lore "&7마녀의 웃음소리가 들리는것같다..", "&7우클릭하여 치장 착용" and "&7거래가 불가능한 아이템입니다."
        else if {_n} is 20:
            send "{@prefix} [2022 할로윈 이벤트] &8&l[&7&l해골 모자&8&l]&f를 획득하였습니다!" to player
            set {_item} to paper named "&8&l[&7&l해골 모자&8&l]" with custom model data 79 with lore "&7해골이 쓰고다니던 모자다...으스스하군 ....", "&7우클릭하여 치장 착용" and "&7거래가 불가능한 아이템입니다."
        else if {_n} is 21:
            send "{@prefix} [2022 할로윈 이벤트] &8&l[검은고양이 머리띠]&f를 획득하였습니다!" to player
            set {_item} to paper named "&8&l[검은고양이 머리띠]" with custom model data 81 with lore "&7검은고양이 네로 ~ 네로 ~ 네로", "&7우클릭하여 치장 착용" and "&7거래가 불가능한 아이템입니다."
        else if {_n} is 22:
            send "{@prefix} [2022 할로윈 이벤트] &b&l[&f&l꼬마 유령 어깨 장식&b&l]&f를 획득하였습니다!" to player
            set {_item} to paper named "&b&l[&f&l꼬마 유령 어깨 장식&b&l]" with custom model data 80 with lore "&7귀여운 꼬마 유령친구다...", "&7우클릭하여 치장 착용" and "&7거래가 불가능한 아이템입니다."
        else if {_n} is 23:
            send "{@prefix} [2022 크리스마스 이벤트] <##006600>&l산타 <##663300>&l머리띠를 획득하였습니다!" to player
            set {_item} to paper named "<##006600>&l산타 <##663300>&l머리띠" with custom model data 96 with lore "&7우클릭하여 치장 착용" and "&7거래가 불가능한 아이템입니다."
        else if {_n} is 24:
            send "{@prefix} [2022 크리스마스 이벤트] <##FF0000>&l호랑가시 <##666666>&l뱃지&f를 획득하였습니다!" to player
            set {_item} to paper named "<##FF0000>&l호랑가시 <##666666>&l뱃지" with custom model data 87 with lore "&7우클릭하여 치장 착용" and "&7거래가 불가능한 아이템입니다."
        else if {_n} is 25:
            send "{@prefix} [2022 크리스마스 이벤트] <##66360C>&l루돌프 <##E7DE79>&l머리띠&f를 획득하였습니다!" to player
            set {_item} to paper named "<##66360C>&l루돌프 <##E7DE79>&l머리띠" with custom model data 86 with lore "&7우클릭하여 치장 착용" and "&7거래가 불가능한 아이템입니다."
        else if {_n} is 26:
            send "{@prefix} [2022 크리스마스 이벤트] <##FF0000>&l크리스마스 &f&l막대사탕&f을 획득하였습니다!" to player
            set {_item} to paper named "<##FF0000>&l크리스마스 &f&l막대사탕" with custom model data 88 with lore "&7거래가 불가능한 아이템입니다."
        else if {_n} is 27:
            send "{@prefix} [2022 크리스마스 이벤트] &8&l검은색 &f&l목도리&f를 획득하였습니다!" to player
            set {_item} to paper named "&8&l검은색 &f&l목도리" with custom model data 89 with lore "&7우클릭하여 치장 착용" and "&7거래가 불가능한 아이템입니다."
        else if {_n} is 28:
            send "{@prefix} [2022 크리스마스 이벤트] <##B19DC9>&l보라색 &f&l목도리&f를 획득하였습니다!" to player
            set {_item} to paper named "<##B19DC9>&l보라색 &f&l목도리" with custom model data 90 with lore "&7우클릭하여 치장 착용" and "&7거래가 불가능한 아이템입니다."
        else if {_n} is 29:
            send "{@prefix} [2022 크리스마스 이벤트] <##FF0000>&l빨간색 &f&l목도리&f를 획득하였습니다!" to player
            set {_item} to paper named "<##FF0000>&l빨간색 &f&l목도리" with custom model data 91 with lore "&7우클릭하여 치장 착용" and "&7거래가 불가능한 아이템입니다."
        else if {_n} is 30:
            send "{@prefix} [2022 크리스마스 이벤트] &f&l산타 <##FF0000>&l모자&f를 획득하였습니다!" to player
            set {_item} to paper named "&f&l산타 <##FF0000>&l모자" with custom model data 93 with lore "&7우클릭하여 치장 착용" and "&7거래가 불가능한 아이템입니다."
        else if {_n} is 31:
            send "{@prefix} [2022 크리스마스 이벤트] &f&l눈구름&f을 획득하였습니다!" to player
            set {_item} to paper named "&f&l눈구름" with custom model data 94 with lore "&7우클릭하여 치장 착용" and "&7거래가 불가능한 아이템입니다."
        else if {_n} is 32:
            send "{@prefix} [2022 크리스마스 이벤트] &f&l눈사람&f을 획득하였습니다!" to player
            set {_item} to paper named "&f&l눈사람" with custom model data 95 with lore "&7우클릭하여 치장 착용" and "&7거래가 불가능한 아이템입니다."
        itemGive(player, {_item}, 1, "Randombox")

on rightclick with gold ingot:
    if uncolored name of event-item is "[ 임인년 ] 코인" or "[ 임인년 ] 코인 ⚝":
        set {randombox.blacktiger::%uuid of player%} to 0 if {randombox.blacktiger::%uuid of player%} isn't set
        set {_i} to {randombox.blacktiger::%uuid of player%}
        remove 1 of player's tool from player's tool
        set {_n} to random integer between 1 and 200
        if {_n} is between 1 and 20:
            set {_number} to round up ({_n}/5)
            set {_br} to round down ({_i}/(2^({_number}-1)))
            if mod({_br}, 2) is 0:
                add 2^({_number}-1) to {randombox.blacktiger::%uuid of player%}
            else:
                send "{@prefix} 안타깝게도 중복된 아이템이 나와서 &c&l꽝&f입니다!" to player
                stop
            if {_number} is 1:
                send "{@prefix} &8&l검은 호랑이 탈 &7교환권&f을 획득하였습니다!" to player
